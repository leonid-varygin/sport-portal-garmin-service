# Garmin Service Configuration
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development

# API Key для авторизации запросов к основному бэкенду
# Должен совпадать с GARMIN_SERVICE_API_KEY в .env бэкенда
SERVICE_API_KEY=garmin-service-secret-key

# Logging
LOG_LEVEL=INFO

# Garmin Settings
GARMIN_TIMEOUT=30

# Backend URL (основной бэкенд)
BACKEND_URL=http://host.docker.internal:3001/api
